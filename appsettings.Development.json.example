{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=WorkforceManagement;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Key": "CHANGE_ME_Min32CharactersSecretKey!!",
    "Issuer": "WorkforceManagement.Api",
    "Audience": "WorkforceManagement.Frontend",
    "ExpiryMinutes": "480"
  },
  "Cors": {
    "Origins": "http://localhost:5174,http://localhost:5175,http://localhost:5176"
  }
}
